# ============================================================
# exam_parser_be — biến môi trường. Copy thành .env: cp .env.example .env
# ============================================================

# --- AI service (exam_parser_paddle HOẶC exam_parser_mineru) — điểm thay thế AI ---
# API + Mongo (exam_parser.exams) + MinIO (bucket exam-parser) của 2 service GIỐNG NHAU
# → đổi service = chỉ đổi URL này, KHÔNG sửa code BE.
# >>> Cách B: gọi exam_parser_mineru ở cổng 8001 <<<
#   Chạy local (host):    http://localhost:8001
#   Chạy Docker cùng máy: http://host.docker.internal:8001  (compose đã set sẵn)
#   (Quay lại paddle ở 8000: đổi cổng về 8000.)
AI_SERVICE_URL=http://localhost:8001
AI_TIMEOUT=600

# --- Store DUY NHẤT (POC): Mongo + MinIO của AI service (db exam_parser) ---
# BE KHÔNG có Mongo riêng. AI service ghi kết quả vào đây; BE đọc read-only để
# list lịch sử đề + lấy chi tiết + ảnh crop convert base64.
# Chạy Docker cùng máy: thay localhost = host.docker.internal (compose đã set sẵn).
AI_MONGO_URI=mongodb://admin:admin12345@localhost:27017/?authSource=admin
AI_MONGO_DB=exam_parser
AI_MONGO_COLLECTION=exams
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=admin12345
MINIO_BUCKET=exam-parser
MINIO_SECURE=false

# --- Upload ---
MAX_UPLOAD_MB=50
ALLOWED_EXT=.pdf,.png,.jpg,.jpeg

# --- API ---
API_HOST=0.0.0.0
API_PORT=9000
CORS_ORIGINS=*

# --- Logging ---
LOG_LEVEL=INFO
