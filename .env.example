# ============================================================
# exam_parser_be — biến môi trường. Copy thành .env: cp .env.example .env
# ============================================================

# --- AI service (exam_parser_paddle) — điểm thay thế AI ---
# Chạy local (host):      http://localhost:8000
# Chạy Docker cùng máy:   http://host.docker.internal:8000  (compose đã set sẵn)
AI_SERVICE_URL=http://localhost:8000
AI_TIMEOUT=300

# --- MongoDB lịch sử job BE (riêng Mongo của AI service) ---
# Chạy Docker compose: cổng map ra 27018
MONGO_URI=mongodb://admin:admin12345@localhost:27018/?authSource=admin
MONGO_DB=exam_parser_be
MONGO_COLLECTION=be_jobs

# Chỉ dùng cho compose (thay ${...}):
BE_MONGO_USER=admin
BE_MONGO_PASS=admin12345
BE_MONGO_DB=exam_parser_be

# --- AI history store (read-only): Mongo + MinIO của AI service ---
# Để list lịch sử đề + lấy ảnh crop convert base64. Trỏ tới Mongo/MinIO của AI service.
# Chạy Docker cùng máy: thay localhost = host.docker.internal (compose đã set sẵn).
AI_MONGO_URI=mongodb://admin:admin12345@localhost:27017/?authSource=admin
AI_MONGO_DB=exam_parser
AI_MONGO_COLLECTION=exams
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=admin12345
MINIO_BUCKET=exam-parser
MINIO_SECURE=false

# --- Upload ---
MAX_UPLOAD_MB=50
ALLOWED_EXT=.pdf,.png,.jpg,.jpeg

# --- API ---
API_HOST=0.0.0.0
API_PORT=9000
CORS_ORIGINS=*

# --- Logging ---
LOG_LEVEL=INFO
